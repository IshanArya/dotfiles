# Private / machine-specific config (do not commit to public repo)

# waybar-weather: approximate home location
config/waybar-weather/geolocation
config/waybar-weather/cityname

# sunsetr / darkman: approximate home location (sunset timing)
config/sunsetr/geo.toml
config/darkman/config.yaml

# hypr: machine-specific, auto-generated by nwg-displays
config/hypr/monitors.conf

# hypr: runtime symlink to active wallpaper (maintained by theme-switch.sh)
config/hypr/.current-wallpaper
