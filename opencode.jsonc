{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "plugin": ["@mohak34/opencode-notifier@latest", "opencode-claude-auth@latest"],
  "mcp": {
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "enabled": true,
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest",
        "--extension"
      ],
      "enabled": false
    }
  },
  "agent": {
    "explore": {
      "model": "anthropic/claude-opus-4-8"
    }
  }
}
