{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "plugin": ["@mohak34/opencode-notifier@latest", "opencode-claude-auth@latest"],
  // , "@angdrew/opencode-hashline-plugin"
  // "provider": {
  //   "anthropic": {
  //     "options": {
  //       "baseURL": "http://127.0.0.1:8484/code/v1",
